@model IEnumerable<QuanLyXemPhim.Models.Entities.User>
@{
    ViewData["Title"] = "Danh sách tài khoản";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold">Quản lý Tài khoản</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Thêm Tài khoản
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="bg-light text-primary">
                <tr>
                    <th class="ps-4">Email</th>
                    <th>Họ tên</th>
                    <th>Số điện thoại</th>
                    <th>Ngày tạo</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@user.Email</td>
                        <td>@user.FullName</td>
                        <td>@(user.PhoneNumber ?? "Chưa có")</td>
                        <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a href="javascript:void(0);"
                               onclick="confirmDelete('@Url.Action("Delete", new { id = user.Id })')"
                               class="btn btn-sm btn-outline-danger" title="Xóa tài khoản">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(url) {
            Swal.fire({
                title: 'Bạn có chắc chắn?',
                text: "Hành động này sẽ xóa vĩnh viễn tài khoản và không thể khôi phục!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33', // Màu đỏ cho nút Xóa
                cancelButtonColor: '#3085d6', // Màu xanh cho nút Hủy
                confirmButtonText: 'Vâng, xóa đi!',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Nếu người dùng bấm nút "Vâng, xóa đi" -> Chuyển hướng đến URL xóa
                    window.location.href = url;
                }
            })
        }
    </script>
}