@model QuanLyXemPhim.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Admin";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark border-start border-5 border-primary ps-3 mb-1">
                TỔNG QUAN HỆ THỐNG
            </h2>
            <p class="text-muted ps-4 mb-0">Chào mừng quay trở lại trang quản trị</p>
        </div>
        <span class="badge bg-light text-dark border p-2 shadow-sm">
            <i class="bi bi-clock me-1"></i> Cập nhật: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
        </span>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-white card-gradient-green h-100 hover-scale">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <div class="icon-circle mb-3 bg-white bg-opacity-25 text-white">
                            <i class="bi bi-currency-dollar fs-4"></i>
                        </div>
                        <p class="mb-1 opacity-75 fw-bold text-uppercase small">Tổng Doanh Thu</p>
                        <h3 class="fw-bold mb-0">@Model.TotalRevenue.ToString("#,##0") đ</h3>
                    </div>
                    <div class="opacity-25 display-1 position-absolute end-0 top-50 translate-middle-y me-3">
                        <i class="bi bi-wallet2"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-white card-gradient-blue h-100 hover-scale">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <div class="icon-circle mb-3 bg-white bg-opacity-25 text-white">
                            <i class="bi bi-ticket-perforated fs-4"></i>
                        </div>
                        <p class="mb-1 opacity-75 fw-bold text-uppercase small">Vé Đã Bán</p>
                        <h3 class="fw-bold mb-0">@Model.TotalOrders</h3>
                    </div>
                    <div class="opacity-25 display-1 position-absolute end-0 top-50 translate-middle-y me-3">
                        <i class="bi bi-cart-check"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-white card-gradient-orange h-100 hover-scale">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <div class="icon-circle mb-3 bg-white bg-opacity-25 text-white">
                            <i class="bi bi-film fs-4"></i>
                        </div>
                        <p class="mb-1 opacity-75 fw-bold text-uppercase small">Phim Đang Có</p>
                        <h3 class="fw-bold mb-0">Loading...</h3>
                    </div>
                    <div class="opacity-25 display-1 position-absolute end-0 top-50 translate-middle-y me-3">
                        <i class="bi bi-collection-play"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-white card-gradient-purple h-100 hover-scale">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <div class="icon-circle mb-3 bg-white bg-opacity-25 text-white">
                            <i class="bi bi-people fs-4"></i>
                        </div>
                        <p class="mb-1 opacity-75 fw-bold text-uppercase small">Thành Viên</p>
                        <h3 class="fw-bold mb-0">Loading...</h3>
                    </div>
                    <div class="opacity-25 display-1 position-absolute end-0 top-50 translate-middle-y me-3">
                        <i class="bi bi-person-badge"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center flex-wrap">
                    <div>
                        <h5 class="fw-bold text-dark mb-1">
                            <i class="bi bi-graph-up-arrow text-primary me-2"></i>Biểu Đồ Doanh Thu
                        </h5>
                        <small class="text-muted">Dữ liệu 7 ngày gần nhất</small>
                    </div>

                    <div class="d-flex gap-2">
                        <select class="form-select form-select-sm border-light shadow-sm bg-light" style="width: 130px;">
                            <option>Theo ngày</option>
                            <option>Theo tháng</option>
                        </select>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div style="height: 400px;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h5 class="mb-3 text-dark fw-bold border-start border-4 border-warning ps-3">TRUY CẬP NHANH</h5>
    <div class="row g-3">
        <div class="col-md-4">
            <a asp-controller="Movie" asp-action="Index" class="card text-decoration-none shadow-sm h-100 hover-border border-0 bg-light">
                <div class="card-body d-flex align-items-center p-3">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3 text-primary">
                        <i class="bi bi-film fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold text-dark mb-1">Quản lý Phim</h6>
                        <small class="text-muted">Thêm/Sửa/Xóa phim</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Showtime" asp-action="Index" class="card text-decoration-none shadow-sm h-100 hover-border border-0 bg-light">
                <div class="card-body d-flex align-items-center p-3">
                    <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3 text-success">
                        <i class="bi bi-calendar-event fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold text-dark mb-1">Lịch Chiếu</h6>
                        <small class="text-muted">Xếp lịch chiếu phim</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/" class="card text-decoration-none shadow-sm h-100 hover-border border-0 bg-light">
                <div class="card-body d-flex align-items-center p-3">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-3 text-warning">
                        <i class="bi bi-house-door fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold text-dark mb-1">Trang Chủ</h6>
                        <small class="text-muted">Xem giao diện khách hàng</small>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    /* Gradient Colors */
    .card-gradient-green {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }

    .card-gradient-blue {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
    }

    .card-gradient-orange {
        background: linear-gradient(135deg, #FF8008 0%, #FFC837 100%);
    }

    .card-gradient-purple {
        background: linear-gradient(135deg, #8E2DE2 0%, #4A00E0 100%);
    }

    .icon-circle {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hover-scale {
        transition: transform 0.3s;
    }

        .hover-scale:hover {
            transform: translateY(-5px);
        }

    .hover-border {
        transition: 0.2s;
        border: 1px solid transparent !important;
    }

        .hover-border:hover {
            border-color: #0d6efd !important;
            background: white !important;
        }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Lấy dữ liệu từ C# truyền sang JS
        var labels = @Json.Serialize(Model.ChartLabels);
        var data = @Json.Serialize(Model.ChartValues);

        var ctx = document.getElementById('revenueChart').getContext('2d');
        var myChart = new Chart(ctx, {
            type: 'line', // Biểu đồ đường cho đẹp (giống ảnh mẫu 2)
            data: {
                labels: labels,
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: data,
                    borderColor: '#38ef7d', // Màu đường xanh lá
                    backgroundColor: 'rgba(56, 239, 125, 0.1)', // Màu nền mờ dưới đường
                    borderWidth: 3,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#11998e',
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    fill: true,
                    tension: 0.4 // Làm cong đường biểu đồ cho mượt
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { borderDash: [5, 5], color: '#f0f0f0' },
                        ticks: {
                            callback: function(value) { return value.toLocaleString('vi-VN') + ' đ'; }
                        }
                    },
                    x: {
                        grid: { display: false }
                    }
                }
            }
        });
    </script>
}