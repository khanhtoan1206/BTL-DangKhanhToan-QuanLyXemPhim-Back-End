<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        body {
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            background-color: #f8f9fa;
        }

        #sidebar-wrapper {
            min-width: 250px;
            max-width: 250px;
            background-color: #212529;
            color: white;
            transition: all 0.3s;
        }

        .sidebar-heading {
            padding: 1.5rem;
            font-size: 1.2rem;
            font-weight: bold;
            text-align: center;
            background: #000;
        }

        .list-group-item {
            background-color: transparent;
            color: #adb5bd;
            border: none;
            padding: 15px 20px;
            transition: 0.2s;
        }

            .list-group-item:hover {
                background-color: #343a40;
                color: #fff;
                cursor: pointer;
            }

            .list-group-item.active {
                background-color: #0d6efd;
                color: white;
                font-weight: bold;
                border-left: 4px solid #fff; /* Thêm viền trái cho đẹp */
            }

        #page-content-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
    </style>
</head>
<body>

    <div id="sidebar-wrapper">
        <div class="sidebar-heading text-uppercase text-primary">
            <i class="fas fa-user-shield"></i> Admin Panel
        </div>
        <div class="list-group list-group-flush mt-3">

            <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="bi bi-speedometer2 me-2"></i> Dashboard
            </a>

            <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Banner" ? "active" : "")">
                <i class="bi bi-images me-2"></i> Quản lý Banner
            </a>

            <a asp-area="Admin" asp-controller="Movie" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Movie" ? "active" : "")">
                <i class="bi bi-film me-2"></i> Quản lý Phim
            </a>

            <a asp-area="Admin" asp-controller="CinemaRoom" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "CinemaRoom" ? "active" : "")">
                <i class="bi bi-shop-window me-2"></i> Quản lý Phòng
            </a>

            <a asp-area="Admin" asp-controller="Showtime" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Showtime" ? "active" : "")">
                <i class="bi bi-calendar-date me-2"></i> Lịch Chiếu
            </a>

            <a asp-area="Admin" asp-controller="User" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")">
                <i class="bi bi-people me-2"></i> Tài Khoản
            </a>

            <hr class="border-secondary mx-3">

            <a href="/" class="list-group-item list-group-item-action text-warning">
                <i class="bi bi-house-door me-2"></i> Về trang web
            </a>
        </div>
    </div>

    <div id="page-content-wrapper">
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm px-4">
            <h4 class="my-auto text-uppercase fw-bold text-dark">@ViewData["Title"]</h4>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav ms-auto mt-2 mt-lg-0">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-primary" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i> Xin chào, Admin
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="navbarDropdown">
                            <li>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger fw-bold">
                                        <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </nav>

        <div class="container-fluid py-4 px-4">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Success"] != null)
    {
        <script>
            var successMessage = @Html.Raw(Json.Serialize(TempData["Success"]))
            Swal.fire({
                icon: 'success',
                title: 'Thành công',
                text: successMessage,
                confirmButtonColor: '#3085d6',
                timer: 2000
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            var errorMessage = @Html.Raw(Json.Serialize(TempData["Error"]))
            Swal.fire({
                icon: 'error',
                title: 'Lỗi!',
                text: errorMessage,
                confirmButtonColor: '#d33',
                timer: 3000
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>