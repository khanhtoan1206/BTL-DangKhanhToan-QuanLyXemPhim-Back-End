@model QuanLyXemPhim.Models.Entities.Banner
@{
    ViewData["Title"] = "Xóa Banner";
}

<div class="container p-5">
    <div class="card border-0 shadow rounded-4 mx-auto text-center" style="max-width: 500px;">
        <div class="card-body p-5">
            <div class="text-danger display-1 mb-3"><i class="bi bi-exclamation-circle"></i></div>
            <h3 class="fw-bold mb-2">Xác nhận xóa?</h3>
            <p class="text-muted mb-4">Bạn có chắc chắn muốn xóa Banner: <strong>@Model.Title</strong> không?</p>

            <img src="@Model.ImageUrl" class="img-fluid rounded mb-4 shadow-sm" style="max-height: 150px;">

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-light rounded-pill px-4">Hủy bỏ</a>
                <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Xóa ngay</button>
            </form>
        </div>
    </div>
</div>