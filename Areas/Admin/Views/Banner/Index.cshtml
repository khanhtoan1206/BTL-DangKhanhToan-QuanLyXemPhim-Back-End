@model IEnumerable<QuanLyXemPhim.Models.Entities.Banner>
@{
    ViewData["Title"] = "Quản lý Banner";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary border-start border-5 border-primary ps-3 text-uppercase">
            Quản lý Banner
        </h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
            <i class="bi bi-plus-circle me-2"></i>Thêm Banner Mới
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="text-center py-3" style="width: 15%;">Ảnh</th>
                        <th style="width: 35%;">Tiêu đề & Mô tả</th>
                        <th class="text-center" style="width: 15%;">Thứ tự</th>
                        <th class="text-center" style="width: 15%;">Trạng thái</th>
                        <th class="text-end pe-4" style="width: 20%;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center p-3">
                                    <img src="@item.ImageUrl" class="rounded shadow-sm border"
                                         style="width: 120px; height: 60px; object-fit: cover;"
                                         onerror="this.src='https://via.placeholder.com/120x60?text=No+Image'">
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@(item.Title ?? "Không có tiêu đề")</div>
                                    <small class="text-muted text-truncate d-block" style="max-width: 300px;">
                                        @(item.Description ?? "Chưa có mô tả")
                                    </small>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border rounded-pill px-3">#@item.DisplayOrder</span>
                                </td>
                                <td class="text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1">
                                            <i class="bi bi-check-circle-fill me-1"></i>Hiển thị
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-2 py-1">
                                            <i class="bi bi-eye-slash-fill me-1"></i>Đang ẩn
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="bi bi-images display-1 d-block mb-3 opacity-25"></i>
                                    <h5>Chưa có banner nào!</h5>
                                    <p class="mb-3">Hãy thêm banner đầu tiên để trang trí cho trang chủ.</p>
                                    <a asp-action="Create" class="btn btn-sm btn-primary px-3">
                                        + Thêm ngay
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>