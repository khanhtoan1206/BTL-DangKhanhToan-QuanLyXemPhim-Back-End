@model QuanLyXemPhim.Models.Entities.Banner
@{
    ViewData["Title"] = "Thêm Banner";
}

<div class="container p-4">
    <div class="card border-0 shadow-sm rounded-4 mx-auto" style="max-width: 800px;">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <h4 class="fw-bold text-primary">Thêm Banner Mới</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Đường dẫn ảnh (URL) <span class="text-danger">*</span></label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." required />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tiêu đề lớn</label>
                        <input asp-for="Title" class="form-control" placeholder="VD: THẾ GIỚI ĐIỆN ẢNH" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Link khi bấm vào</label>
                        <input asp-for="LinkUrl" class="form-control" placeholder="VD: /phim/doraemon" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Mô tả ngắn</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Mô tả nhỏ bên dưới tiêu đề"></textarea>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Thứ tự hiển thị</label>
                        <input asp-for="DisplayOrder" class="form-control" type="number" value="1" />
                    </div>

                    <div class="col-md-6 d-flex align-items-center pt-4">
                        <div class="form-check form-switch fs-5">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" checked />
                            <label class="form-check-label ms-2" asp-for="IsActive">Kích hoạt ngay</label>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Lưu Banner</button>
                </div>
            </form>
        </div>
    </div>
</div>