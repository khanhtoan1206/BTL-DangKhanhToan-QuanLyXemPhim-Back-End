@model QuanLyXemPhim.Models.Entities.Showtime

@{
    ViewData["Title"] = "Tạo Lịch Chiếu";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-0 mt-4">
            <div class="card-header bg-success bg-gradient ml-0 py-3">
                <h2 class="text-white text-center py-2">Xếp Lịch Chiếu Mới</h2>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Chọn Phim</label>
                        <select asp-for="MovieId" class="form-select" asp-items="ViewBag.MovieId"></select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Chọn Phòng</label>
                        <select asp-for="CinemaRoomId" class="form-select" asp-items="ViewBag.CinemaRoomId"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="StartTime" class="form-label fw-bold"></label>
                        <input asp-for="StartTime" class="form-control" type="datetime-local"
                               value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="StartTime" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BasePrice" class="form-label fw-bold"></label>
                        <input asp-for="BasePrice" class="form-control" type="number" step="1000" />
                        <span asp-validation-for="BasePrice" class="text-danger"></span>
                    </div>

                    <div class="row pt-2">
                        <div class="col-6">
                            <button type="submit" class="btn btn-success form-control">Lưu Lịch</button>
                        </div>
                        <div class="col-6">
                            <a asp-action="Index" class="btn btn-outline-secondary form-control">Quay lại</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}