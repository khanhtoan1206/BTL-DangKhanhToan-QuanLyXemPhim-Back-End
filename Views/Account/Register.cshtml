@model QuanLyXemPhim.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white text-center rounded-top-4 py-3">
                    <h4 class="mb-0 fw-bold text-uppercase">Đăng Ký Tài Khoản</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3 fw-bold"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ và tên</label>
                            <input asp-for="FullName" class="form-control rounded-pill px-3" placeholder="Nhập họ tên đầy đủ..." />
                            <span asp-validation-for="FullName" class="text-danger small ms-2"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <input asp-for="Email" class="form-control rounded-pill px-3" placeholder="Nhập email..." />
                            <span asp-validation-for="Email" class="text-danger small ms-2"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input asp-for="PhoneNumber" class="form-control rounded-pill px-3" placeholder="Nhập số điện thoại..." />
                            <span asp-validation-for="PhoneNumber" class="text-danger small ms-2"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu</label>
                            <div class="input-group">
                                <input asp-for="Password" type="password" class="form-control rounded-start-pill ps-3" id="regPass" placeholder="Tối thiểu 6 ký tự..." />
                                <span class="input-group-text rounded-end-pill cursor-pointer bg-white border-start-0" onclick="togglePassword('regPass', 'regIcon')">
                                    <i class="bi bi-eye-slash" id="regIcon"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small ms-2"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" type="password" class="form-control rounded-start-pill ps-3" id="confirmPass" placeholder="Nhập lại mật khẩu..." />
                                <span class="input-group-text rounded-end-pill cursor-pointer bg-white border-start-0" onclick="togglePassword('confirmPass', 'confirmIcon')">
                                    <i class="bi bi-eye-slash" id="confirmIcon"></i>
                                </span>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small ms-2"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-success rounded-pill fw-bold py-2 shadow-sm">
                                <i class="bi bi-person-plus-fill"></i> ĐĂNG KÝ NGAY
                            </button>
                        </div>

                        <div class="text-center mt-3">
                            <span class="text-muted">Đã có tài khoản?</span>
                            <a asp-action="Login" class="text-decoration-none fw-bold text-success">Đăng nhập</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye-slash");
            }
        }
    </script>
    <style>
        .cursor-pointer {
            cursor: pointer;
        }

        .input-group-text i {
            color: #6c757d;
        }

        .input-group-text:hover i {
            color: #198754;
        }
        /* Màu xanh lá cho trang đăng ký */
    </style>
}