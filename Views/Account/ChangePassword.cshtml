@model QuanLyXemPhim.Models.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-warning text-dark text-center rounded-top-4">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-key"></i> Đổi Mật Khẩu</h4>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3 fw-bold"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                            <div class="input-group">
                                <input asp-for="OldPassword" type="password" class="form-control" id="currentPass" placeholder="Nhập mật khẩu cũ..." />
                                <span class="input-group-text cursor-pointer" onclick="togglePassword('currentPass', 'iconCurrent')">
                                    <i class="bi bi-eye-slash" id="iconCurrent"></i>
                                </span>
                            </div>
                            <span asp-validation-for="OldPassword" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu mới</label>
                            <div class="input-group">
                                <input asp-for="NewPassword" type="password" class="form-control" id="newPass" placeholder="Tối thiểu 6 ký tự..." />
                                <span class="input-group-text cursor-pointer" onclick="togglePassword('newPass', 'iconNew')">
                                    <i class="bi bi-eye-slash" id="iconNew"></i>
                                </span>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Xác nhận mật khẩu mới</label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" type="password" class="form-control" id="confirmPass" placeholder="Nhập lại mật khẩu mới..." />
                                <span class="input-group-text cursor-pointer" onclick="togglePassword('confirmPass', 'iconConfirm')">
                                    <i class="bi bi-eye-slash" id="iconConfirm"></i>
                                </span>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-check-circle"></i> Xác nhận đổi
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                Quay về trang chủ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Hàm xử lý ẩn/hiện mật khẩu
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);

            if (input.type === "password") {
                input.type = "text"; // Hiện mật khẩu
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye"); // Đổi icon thành mắt mở
            } else {
                input.type = "password"; // Ẩn mật khẩu
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash"); // Đổi icon thành mắt đóng
            }
        }
    </script>

    <style>
        .cursor-pointer {
            cursor: pointer;
        }
        /* Tùy chỉnh màu icon cho đẹp */
        .input-group-text i {
            color: #6c757d;
        }

        .input-group-text:hover i {
            color: #0d6efd;
        }
    </style>
}