@{
    ViewData["Title"] = "Nội Quy Rạp Phim CGV";
}

<div class="container mt-4">

    <div class="text-center mb-4">
        <h2 class="fw-bold text-warning">🎬 NHỮNG QUY ĐỊNH TẠI RẠP PHIM CGV</h2>
        <hr />
    </div>

    <div class="card shadow mb-4">
        <div class="card-header bg-danger text-white fw-bold">
            I. NỘI QUY PHÒNG CHIẾU
        </div>

        <div class="card-body">
            <ul class="list-group list-group-flush">
                <li class="list-group-item">📵 Không quay phim, chụp ảnh.</li>
                <li class="list-group-item">🔕 Tắt chuông điện thoại.</li>
                <li class="list-group-item">🚭 Không hút thuốc.</li>
                <li class="list-group-item">🔇 Không gây mất trật tự.</li>
                <li class="list-group-item">❌ Không nhai kẹo cao su.</li>
                <li class="list-group-item">🐶 Không mang thú cưng vào rạp.</li>
                <li class="list-group-item">💼 Bảo quản tài sản cá nhân cẩn thận.</li>
                <li class="list-group-item">🍿 Chỉ thức ăn và nước uống mua tại CGV mới được mang vào rạp.</li>
                <li class="list-group-item">🍺 Không sử dụng rượu bia hoặc chất kích thích trong khuôn viên rạp.</li>
                <li class="list-group-item">⏰ Sau 22h không phục vụ khách dưới 13 tuổi.</li>
                <li class="list-group-item">⏰ Sau 23h không phục vụ khách dưới 16 tuổi.</li>
                <li class="list-group-item">⚠️ Ban quản lý có quyền từ chối khách nếu vi phạm.</li>
                <li class="list-group-item">📹 CGV có hệ thống camera an ninh trong rạp.</li>
            </ul>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header bg-warning fw-bold">
            II. PHÂN LOẠI PHIM THEO ĐỘ TUỔI
        </div>

        <div class="card-body">

            <p class="fw-bold">CGV Việt Nam thông báo tiêu chí phân loại phim theo lứa tuổi:</p>

            <table class="table table-striped table-hover table-bordered text-center">
                <thead class="table-dark">
                    <tr>
                        <th style="width:150px">Phân loại</th>
                        <th>Định nghĩa</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td class="fw-bold text-success">P</td>
                        <td>Phim được phép phổ biến đến người xem ở mọi độ tuổi.</td>
                    </tr>

                    <tr>
                        <td class="fw-bold text-primary">K</td>
                        <td>Phim dành cho khán giả dưới 13 tuổi và phải có người bảo hộ đi cùng.</td>
                    </tr>

                    <tr>
                        <td class="fw-bold text-warning">T13</td>
                        <td>Phim dành cho khán giả từ đủ 13 tuổi trở lên.</td>
                    </tr>

                    <tr>
                        <td class="fw-bold text-danger">T16</td>
                        <td>Phim dành cho khán giả từ đủ 16 tuổi trở lên.</td>
                    </tr>

                    <tr>
                        <td class="fw-bold text-dark">T18</td>
                        <td>Phim dành cho khán giả từ đủ 18 tuổi trở lên.</td>
                    </tr>

                </tbody>
            </table>

        </div>
    </div>

</div>