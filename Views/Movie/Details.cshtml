@model QuanLyXemPhim.Models.Entities.Movie

@{
    ViewData["Title"] = Model.Title;
    var showtimes = ViewBag.Showtimes as List<QuanLyXemPhim.Models.Entities.Showtime>;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            @if (!string.IsNullOrEmpty(Model.TrailerUrl))
            {
                // Xử lý link Youtube
                var videoId = "";
                if (Model.TrailerUrl.Contains("v="))
                {
                    videoId = Model.TrailerUrl.Split("v=").Last();
                }
                else if (Model.TrailerUrl.Contains("youtu.be/"))
                {
                    videoId = Model.TrailerUrl.Split("youtu.be/").Last();
                }

                <div class="ratio ratio-16x9 rounded shadow mb-4">
                    <iframe src="https://www.youtube.com/embed/@videoId" title="Trailer" allowfullscreen></iframe>
                </div>
            }
            else
            {
                <img src="@Model.PosterUrl" class="w-100 rounded shadow mb-4" style="max-height: 400px; object-fit: cover;" />
            }

            <h2 class="fw-bold text-uppercase text-primary">@Model.Title</h2>
            <p class="text-muted">
                <i class="bi bi-clock"></i> @Model.Duration phút |
                <i class="bi bi-calendar"></i> @Model.ReleaseDate.ToString("dd/MM/yyyy") |
                <span class="badge bg-warning text-dark">@Model.Category?.Name</span>
            </p>
            <hr />
            <h5 class="fw-bold">Nội dung phim:</h5>
            <p class="lead" style="font-size: 16px;">@Model.Description</p>

            <div class="row mt-4 p-3 bg-light rounded">
                <div class="col-md-6">
                    <strong><i class="bi bi-person-video3"></i> Đạo diễn:</strong> <br /> @Model.Director
                </div>
                <div class="col-md-6">
                    <strong><i class="bi bi-people-fill"></i> Diễn viên:</strong> <br /> @Model.Cast
                </div>
                <div class="col-md-6 mt-3">
                    <strong><i class="bi bi-flag-fill"></i> Quốc gia:</strong> <br /> @Model.Country?.Name
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <img src="@Model.PosterUrl" class="w-100 rounded shadow mb-4" style="object-fit: cover;" />

            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white text-center fw-bold text-uppercase">
                    <i class="bi bi-ticket-perforated-fill"></i> LỊCH CHIẾU
                </div>
                <div class="card-body">
                    @if (showtimes != null && showtimes.Any())
                    {
                        <div class="d-grid gap-2">
                            @foreach (var showtime in showtimes)
                            {
                                <a asp-controller="Booking" asp-action="Index" asp-route-showtimeId="@showtime.Id"
                                   class="btn btn-outline-dark text-start py-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="fw-bold fs-5">@showtime.StartTime.ToString("HH:mm")</span>
                                            <br />
                                            <span class="small text-muted">@showtime.StartTime.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-success">@showtime.CinemaRoom?.Name</span>
                                            <br />
                                            <small class="text-danger fw-bold">75.000 đ</small>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-calendar-x display-4 text-muted"></i>
                            <p class="text-muted mt-2">Hiện chưa có lịch chiếu.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>